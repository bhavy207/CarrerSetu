# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/careersetu
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/careersetu

# Server Port
PORT=8000

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your_secret_key_here_change_this

# AI/Gemini API Key (if using Gemini for chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Python Backend URL (for recommendations)
PYTHON_BACKEND_URL=http://localhost:8001

# Logging Level
LOG_LEVEL=debug
